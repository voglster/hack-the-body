# === Shared ===
TZ=America/Denver
MONGO_URL=mongodb://mongo:27017
MONGO_DB=hackthebody

# === App (FastAPI + bundled FE) ===
API_KEY=change-me-to-a-long-random-string
APP_PORT=8080
# Same-origin FE doesn't need CORS. Only set this if a separate-origin client hits the API.
CORS_ORIGINS=

# === Garmin Ingestor ===
GARMIN_EMAIL=
GARMIN_PASSWORD=
GARMIN_SESSION_DIR=/data/garmin-session
GARMIN_BACKFILL_DAYS=90
GARMIN_SCHEDULE_CRON=0 4 * * *
