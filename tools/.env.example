# Copy to tools/.env and fill in.
# tools/.env is git-ignored; never commit a real key.

# Where the running API is reachable. Examples:
#   http://hd:8080         (LAN docker host)
#   http://localhost:8000  (local dev)
HTB_API_URL=http://hd:8080

# The same API_KEY value used in the running compose stack.
HTB_API_KEY=replace-me
