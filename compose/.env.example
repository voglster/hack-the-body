# Drop this as `.env` next to docker-compose.yml on the host.

# === Required ===
API_KEY=generate-with-openssl-rand-hex-32
GARMIN_EMAIL=
GARMIN_PASSWORD=

# === Optional ===
TZ=America/Chicago
APP_PORT=8080
# CORS only matters if a separate-origin client (e.g. another machine's browser direct to /metrics)
# hits this — for the bundled FE this can be left empty since it's same-origin.
CORS_ORIGINS=
GARMIN_BACKFILL_DAYS=90
GARMIN_SCHEDULE_CRON=0 4 * * *

# === USDA FoodData Central (food/barcode fallback) ===
# Free key from https://api.data.gov/signup/. Used to look up US grocery
# products that Open Food Facts doesn't have. Leave blank to disable.
USDA_FDC_API_KEY=

# === Coach (local LLM via Ollama) ===
OLLAMA_URL=http://10.0.6.46:11434
OLLAMA_MODEL=glm-4.7-flash:latest

# Comma-separated HH:MM local times the coach fires + sends a push.
COACH_SCHEDULE_LOCAL=07:00,12:00,17:00

# Vitamin nag — push fires at this local time if no supplement entry
# has been logged yet today. Leave blank to disable.
VITAMIN_REMINDER_LOCAL=10:00

# === Weekly review (slow, deep, big local model on framework) ===
# Sunday at COACH_WEEKLY_LOCAL fires generate_weekly_review against
# WEEKLY_OLLAMA_URL using WEEKLY_OLLAMA_MODEL. gpt-oss:120b lives on
# the RTX 4090 box; ~5min runtime is normal.
WEEKLY_OLLAMA_URL=http://10.0.6.45:11434
WEEKLY_OLLAMA_MODEL=gpt-oss:120b
WEEKLY_TIMEOUT_S=600
COACH_WEEKLY_LOCAL=21:00

# Web Push (VAPID). Leave keys blank to auto-generate on first start
# (persisted in user_profile collection so they stay stable across restarts).
VAPID_SUBJECT=mailto:hack-the-body@local
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# === Treadmill bridge (ESP8266 CSAFE relay on the LAN) ===
# IP works from inside a docker bridge network (mDNS .local does not).
TREADMILL_BRIDGE_HOST=10.0.6.180
TREADMILL_BRIDGE_PORT=8023
